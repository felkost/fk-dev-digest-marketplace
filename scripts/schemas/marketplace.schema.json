{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Claude Code plugin marketplace.json",
  "type": "object",
  "required": ["name", "owner", "plugins"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "kebab-case, no spaces"
    },
    "description": { "type": "string" },
    "version": { "type": "string" },
    "owner": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "email": { "type": "string" }
      }
    },
    "renames": {
      "type": "object",
      "additionalProperties": { "type": ["string", "null"] }
    },
    "allowCrossMarketplaceDependenciesOn": {
      "type": "array",
      "items": { "type": "string" }
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "source"],
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "source": {
            "type": "string",
            "pattern": "^\\./"
          },
          "description": { "type": "string" },
          "version": { "type": "string" },
          "category": { "type": "string" },
          "keywords": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
