# Copy to .env and fill in. Never commit the filled-in file.
# Every name here is read by settings.py; tests/smoke_test.py fails the build
# when the code and this file drift apart.

# --- Chat model (generation) ---------------------------------------------
# OpenRouter serves chat completions. It does NOT document an embeddings
# endpoint, which is why embeddings below use a separate provider.
OPENROUTER_API_KEY=
CHAT_MODEL=openai/gpt-4o-mini

# --- Embedding model (retrieval) -----------------------------------------
# Any OpenAI-compatible /v1/embeddings endpoint. Default is a local Ollama, so
# the corpus never leaves the host and only one paid key is needed.
#   ollama pull nomic-embed-text
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=not-needed-for-local
EMBEDDING_MODEL=nomic-embed-text

# --- Store ----------------------------------------------------------------
# Matches the compose service below; change the password before any real use.
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag

# --- Retrieval tuning -----------------------------------------------------
# Measured in whitespace words by the example's splitter; production must
# measure in the embedding model's tokens (see references/rag-example.md).
CHUNK_SIZE=120
CHUNK_OVERLAP=20
TOP_K=5
