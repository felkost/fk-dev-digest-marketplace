# Copy to .env and fill in. Never commit the filled-in file.
# Every name here is read by agent.py; tests/smoke_test.py fails the build
# when the code and this file drift apart.
#
# Only agent.py needs this -- guardrail_core.py needs no key at all, the
# review and the decision point are plain Python, not model calls.

OPENROUTER_API_KEY=
CHAT_MODEL=openai/gpt-4o-mini
